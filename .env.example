# MTG Multiverse Studio - Environment Variables
# Copy this to .env and fill in your API keys

# Scryfall API (Scryfall) - Public API, no key required

# Cardmarket (MKM) API - OAuth 1.0a
# Get from: https://www.cardmarket.com/en/Magic/Account/API
CARDMARKET_APP_KEY=your_app_key_here
CARDMARKET_APP_SECRET=your_app_secret_here
CARDMARKET_ACCESS_TOKEN=your_access_token_here
CARDMARKET_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# TCGPlayer API - OAuth 2.0
# Get from: https://developer.tcgplayer.com/
TCGPLAYER_PUBLIC_KEY=your_public_key_here
TCGPLAYER_PRIVATE_KEY=your_private_key_here